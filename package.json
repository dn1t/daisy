{
  "name": "@daisy/workspace",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:web": "pnpm run --filter \"@daisy/web\" dev",
    "dev:ext": "pnpm run --filter \"@daisy/extension\" dev",
    "build:web": "pnpm run --filter \"@daisy/web\" build",
    "build:ext": "pnpm run --filter \"@daisy/extension\" build",
    "db:generate": "pnpx auth@rc generate --config packages/auth/auth.ts --output packages/db/schema.ts --yes"
  },
